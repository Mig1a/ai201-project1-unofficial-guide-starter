# Default path is fully local and requires no API key.
EMBEDDING_PROVIDER=local_tfidf
EMBEDDING_MODEL=local_tfidf

LLM_PROVIDER=extractive
LLM_MODEL=extractive

VECTOR_STORE=json

# Required only when using OpenAI providers:
# EMBEDDING_PROVIDER=openai and/or LLM_PROVIDER=openai
OPENAI_API_KEY=

# Optional when using LLM_PROVIDER=ollama.
OLLAMA_URL=http://localhost:11434/api/generate
